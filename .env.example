# Supabase PostgreSQL connection string.
# Local development: use the Supabase Session Pooler connection string.
# Vercel/serverless: use the Supabase Transaction Pooler connection string.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase public settings for browser/server auth clients.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
