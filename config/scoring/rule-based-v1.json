{
  "modelVersion": "rule-based-v1",
  "scoreRange": {
    "base": 50,
    "min": 0,
    "max": 100
  },
  "features": {
    "horse.has_past_race": {
      "type": "boolean",
      "positiveValue": true,
      "positiveAdjustment": 1.5,
      "negativeAdjustment": -2
    },
    "horse.is_after_layoff_8w": {
      "type": "boolean",
      "positiveValue": false,
      "positiveAdjustment": 1,
      "negativeAdjustment": -2
    },
    "horse.days_since_last_race": {
      "type": "interval_days",
      "shortThresholdDays": 10,
      "goodMaxDays": 35,
      "layoffThresholdDays": 56,
      "shortAdjustment": -2,
      "goodAdjustment": 2,
      "standardAdjustment": 1,
      "layoffAdjustment": -2
    },
    "horse.surface_top3_rate": {
      "type": "rate",
      "baseline": 0.33,
      "maxAdjustment": 8
    },
    "horse.distance_top3_rate": {
      "type": "rate",
      "baseline": 0.33,
      "maxAdjustment": 8
    },
    "horse.track_condition_top3_rate": {
      "type": "rate",
      "baseline": 0.33,
      "maxAdjustment": 5
    },
    "horse.course_top3_rate": {
      "type": "rate",
      "baseline": 0.33,
      "maxAdjustment": 6
    },
    "horse.best_time_same_surface_distance": {
      "type": "best_time",
      "featureKey": "horse.best_time_same_surface_distance_ms",
      "countFeatureKey": "horse.best_time_same_surface_distance_count",
      "baseAdjustment": 2,
      "minConfidence": 0.25,
      "fullConfidenceCount": 4,
      "defaultConfidence": 0.5
    },
    "jockey.venue_win_rate": {
      "type": "rate",
      "baseline": 0.33,
      "maxAdjustment": 4
    },
    "jockey.venue_top3_rate": {
      "type": "rate",
      "baseline": 0.33,
      "maxAdjustment": 5
    },
    "jockey.distance_win_rate": {
      "type": "rate",
      "baseline": 0.33,
      "maxAdjustment": 4
    },
    "jockey.distance_top3_rate": {
      "type": "rate",
      "baseline": 0.33,
      "maxAdjustment": 5
    }
  }
}
